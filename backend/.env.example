# RoadSoS Backend Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=RoadSoS
APP_VERSION=1.0.0
DEBUG=true
DEMO_MODE=true

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://roadsos:roadsos_secret@localhost:5432/roadsos_db
DATABASE_URL_SYNC=postgresql://roadsos:roadsos_secret@localhost:5432/roadsos_db

# Security (CHANGE IN PRODUCTION)
SECRET_KEY=roadsos-dev-secret-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - Frontend origins
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000","http://localhost:80","http://127.0.0.1:80"]

# Demo Mode Settings
DEMO_CRASH_INTERVAL_SECONDS=45
DEMO_AMBULANCE_UPDATE_INTERVAL_SECONDS=5
DEMO_HOSPITAL_UPDATE_INTERVAL_SECONDS=30

# Bangalore Geography
BANGALORE_LAT=12.9716
BANGALORE_LON=77.5946
BANGALORE_RADIUS_KM=25.0

# Detection Thresholds
CRASH_CONFIRM_THRESHOLD=0.75
CRASH_SUSPECT_THRESHOLD=0.40
SOUND_INTENSITY_THRESHOLD_DB=85.0
SOUND_SCORE_BOOST=0.15

# Emergency Coordination
MAX_AMBULANCE_SEARCH_RADIUS_KM=20.0
MAX_HOSPITALS_TO_RANK=5
NOTIFICATION_TIMEOUT_SECONDS=5

# Risk Prediction
BLACKSPOT_RISK_THRESHOLD=70.0
